apiVersion: cilium.io/v2alpha1
kind: CiliumLoadBalancerIPPool
metadata:
  name: homelab-pool
spec:
  blocks:
{% for block in cilium_loadbalancer_pool %}
    - start: "{{ block.start }}"
      stop: "{{ block.stop }}"
{% endfor %}
---
apiVersion: cilium.io/v2alpha1
kind: CiliumL2AnnouncementPolicy
metadata:
  name: homelab-l2
spec:
  externalIPs: true
  loadBalancerIPs: true
  interfaces:
    - eth0
